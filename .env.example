# MCP server
NEWS_HOST=127.0.0.1
NEWS_PORT=10110
NEWS_TRANSPORT=streamable-http

# GDELT upstream
NEWS_GDELT_TIMEOUT=30

# Global outbound proxy for all network requests
# Also accepts PROXY_ENABLE / PROXY_URL without the NEWS_ prefix.
# When enabled, all HTTP requests in this service should use this proxy.
# NEWS_PROXY_ENABLE=true
# NEWS_PROXY_URL=http://127.0.0.1:7890

# Optional feed/proxy settings for future RSS-based tools
# APP_ENV=dev
# NEWS_API_BASE=
# NEWS_RSS_DIRECT_TO_RELAY=false
# NEWS_RSS_PROXY_BASE=

# Database storage
# NEWS_DATABASE_BACKEND=sqlite
# NEWS_SQLITE_PATH=data/news.db
# NEWS_DATABASE_AUTO_MIGRATE=true
#
# Or use a full SQLAlchemy URL instead:
# NEWS_DATABASE_URL=sqlite+aiosqlite:///./data/news.db
# NEWS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/open_news_mcp

# Feed sync worker
# NEWS_FEEDS_SYNC_INTERVAL_HIGH_MINUTES=5
# NEWS_FEEDS_SYNC_INTERVAL_NORMAL_MINUTES=10
# NEWS_FEEDS_SYNC_INTERVAL_LOW_MINUTES=30
# NEWS_FEEDS_SYNC_LIMIT_PER_FEED=20
# NEWS_FEEDS_SYNC_REQUEST_TIMEOUT=20
# NEWS_FEEDS_SYNC_CONCURRENCY=8

# Embedding
# NEWS_EMBEDDING_BACKEND=local
# NEWS_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# NEWS_EMBEDDING_DEVICE=cpu
# NEWS_EMBEDDING_NORMALIZE=true
# NEWS_EMBEDDING_BATCH_SIZE=16
# NEWS_EMBEDDING_TRUST_REMOTE_CODE=true
#
# External providers are not implemented yet, but config is reserved:
# NEWS_EMBEDDING_BACKEND=openai
# NEWS_EMBEDDING_OPENAI_API_KEY=
# NEWS_EMBEDDING_OPENAI_BASE_URL=
# NEWS_EMBEDDING_BACKEND=google
# NEWS_EMBEDDING_GOOGLE_API_KEY=
# NEWS_EMBEDDING_GOOGLE_BASE_URL=
# NEWS_EMBEDDING_BACKEND=openrouter
# NEWS_EMBEDDING_OPENROUTER_API_KEY=
# NEWS_EMBEDDING_OPENROUTER_BASE_URL=

# Vector store
# NEWS_VECTOR_BACKEND=qdrant
# NEWS_VECTOR_COLLECTION=news_articles
# NEWS_VECTOR_DISTANCE=cosine
#
# Qdrant remote mode
# NEWS_QDRANT_URL=http://127.0.0.1:6333
# NEWS_QDRANT_API_KEY=
# NEWS_QDRANT_TIMEOUT=10
# NEWS_QDRANT_PREFER_GRPC=false
#
# Qdrant local mode
# NEWS_QDRANT_PATH=data/qdrant
